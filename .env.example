# MeshForge — Variables d'environnement (modèle)
# Ne JAMAIS committer les fichiers réels (.env / .env.local).

# === docker compose (copier dans .env) =====================================
# Mot de passe TimescaleDB. Défaut "meshforge" si absent (dev local).
# En prod Docker, il est passé brut à Postgres/app/worker/mosquitto : les
# caractères spéciaux sont OK, pas besoin de l'encoder en URL.
DB_PASSWORD=meshforgeTestDev

# === App Next.js + worker MQTT (copier dans .env.local) =====================
# Base de données
# Dev hors Docker uniquement. Si le mot de passe contient des caractères
# spéciaux dans cette URL, il doit être URL-encodé.
DATABASE_URL=postgresql://meshforge:meshforgeTestDev@localhost:5432/meshforge

# Broker MQTT (uplink only)
MQTT_URL=mqtt://localhost:1883
MQTT_USERNAME=          # vide en dev
MQTT_PASSWORD=          # vide en dev

# Clés PSK Meshtastic pour décoder les topics /e/ chiffrés.
# Format : NomCanal:base64,AutreCanal:base64
# Laisser vide désactive le décodage /e/ et évite les doublons quand /json/ existe.
MESHTASTIC_CHANNEL_KEYS=Fr_Balise:AQ==,Fr_BlaBla:AQ==,Fr_EMCOM:AQ==
# Debug local des paquets protobuf /e/ : logs raison de drop/décodage.
MQTT_PROTO_DEBUG=1

# Admin — secret de signature du cookie de session (HMAC). SANS lui, l'accès
# admin est refusé. Générer : openssl rand -hex 32
# Les comptes admin eux-mêmes vivent en DB (table contributors, role=ADMIN) :
# créer le premier compte admin avec la commande `yarn create-admin`.
ADMIN_SESSION_SECRET=ADMIN_SESSION_SECRET_MESHFORGE_LOCAL

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Affiche les lignes du script seed-coverage-tiles.sql dans la couche locale.
# Ignoré en production même si la variable est accidentellement définie.
COVERAGE_INCLUDE_DEMO=0
