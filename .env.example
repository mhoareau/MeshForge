# MeshForge — Variables d'environnement (modèle)
# Ne JAMAIS committer les fichiers réels (.env / .env.local).

# === docker compose (copier dans .env) =====================================
# Mot de passe TimescaleDB. Défaut "meshforge" si absent (dev local).
DB_PASSWORD=meshforge

# === App Next.js + worker MQTT (copier dans .env.local) =====================
# Base de données
DATABASE_URL=postgresql://meshforge:meshforge@localhost:5432/meshforge

# Broker MQTT (uplink only)
MQTT_URL=mqtt://localhost:1883
MQTT_USERNAME=          # vide en dev
MQTT_PASSWORD=          # vide en dev

# Privacy — l'allowlist des canaux publics (default-deny) est désormais en DB
# (table `settings`, clé `public_channels`), éditable sur /admin/config. Le
# worker la relit toutes les 30s. Défaut seedé : Fr_Balise, Fr_EMCOM, Fr_BlaBla.

# NB : la config runtime (seuil "node bavard", canaux publics à venir, etc.) est
# désormais en DB (table `settings`), éditable sur /admin/config — plus en .env.

# Admin — secret de signature du cookie de session (HMAC). SANS lui, l'accès
# admin est refusé. Générer : openssl rand -hex 32
# Les comptes admin eux-mêmes vivent en DB (table contributors, role=ADMIN) :
# créer le premier avec `yarn create-admin`.
ADMIN_SESSION_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
