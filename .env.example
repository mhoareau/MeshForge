# MeshForge — Variables d'environnement (modèle)
# Ne JAMAIS committer les fichiers réels (.env / .env.local).

# === docker compose (copier dans .env) =====================================
# Mot de passe TimescaleDB. Défaut "meshforge" si absent (dev local).
DB_PASSWORD=meshforge

# === App Next.js + worker MQTT (copier dans .env.local) =====================
# Base de données
DATABASE_URL=postgresql://meshforge:meshforge@localhost:5432/meshforge

# Broker MQTT (uplink only)
MQTT_URL=mqtt://localhost:1883
MQTT_USERNAME=          # vide en dev
MQTT_PASSWORD=          # vide en dev

# Privacy — allowlist des canaux publics autorisés (default-deny).
# Le worker filtre sur le NOM du canal dans le topic MQTT, pas sur l'index
# `channel` du JSON (peu fiable : les DM chiffrés "PKI" affichent channel:0).
# Tout canal absent de cette liste est ignoré AVANT insertion (DM, canaux
# privés, canaux inconnus). Ajouter un canal public ici sinon il est droppé.
MQTT_PUBLIC_CHANNELS=Fr_Balise,Fr_EMCOM,Fr_BlaBla

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
